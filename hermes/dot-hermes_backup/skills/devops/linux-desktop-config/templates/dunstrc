[global]
    font = Noto Sans 10
    line_height = 0
    separator_height = 2
    padding = 8
    horizontal_padding = 8
    separator_color = frame
    sort = yes
    indicate_hidden = yes
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    shrink = no
    transparency = 10
    idle_threshold = 120
    monitor = 0
    follow = mouse
    sticky_history = yes
    history_length = 20
    show_indicators = yes
    spacing = 4
    startup_notification = true
    dmenu = /usr/bin/dmenu
    browser = /usr/bin/xdg-open

[urgency_low]
    background = "#1a1a1a"
    foreground = "#cccccc"
    timeout = 5

[urgency_normal]
    background = "#222222"
    foreground = "#ffffff"
    timeout = 10

[urgency_critical]
    background = "#DB3279"
    foreground = "#ffffff"
    frame_color = "#EC69A0"
    timeout = 0
